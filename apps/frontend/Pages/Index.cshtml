@page
@model IndexModel
@{
    ViewData["Title"] = "MateBank OIDC + LDAP Groups Demo";
}

<div class="mb-hero">
    <div class="container">
        <div class="mb-3">
            <span class="mb-chip">OIDC + JWT + LDAP Groups</span>
        </div>
        <div class="row align-items-center g-4">
            <div class="col-12 col-lg-7">
                <h1 class="display-5 mb-2">MateBank Identity Demo</h1>
                <p class="lead mb-3">
                    Modern OIDC login with Keycloak + JWT authorization while keeping <strong>LDAP groups</strong> as the source of truth.
                </p>
                <div class="d-flex flex-wrap gap-2">
                    @if (!User.Identity?.IsAuthenticated ?? true)
                    {
                        <a class="btn btn-mb btn-lg" href="/login?returnUrl=/">Sign in</a>
                        <span class="text-muted align-self-center">Use any demo LDAP user to see group-based access.</span>
                    }
                    else
                    {
                        <a class="btn btn-mb btn-lg" asp-page="/Missions">Go to Missions</a>
                        <a class="btn btn-mb-outline btn-lg" asp-page="/Profile">View Profile</a>
                    }
                </div>
            </div>
            <div class="col-12 col-lg-5">
                <div class="mb-glass p-3 p-md-4 rounded-4">
                        <div class="d-flex justify-content-between">
                            <div>
                                <div class="text-muted small">Status</div>
                                <div class="h5 mb-0">@((User.Identity?.IsAuthenticated ?? false) ? "Signed in" : "Signed out")</div>
                            </div>
                            <div class="text-end">
                                <div class="text-muted small">User</div>
                                <div class="h5 mb-0">@((User.Identity?.IsAuthenticated ?? false) ? User.Identity?.Name : "—")</div>
                            </div>
                        </div>
                        <hr />
                        <div class="small text-muted">
                            Tip: try <code>nico.paz</code> for a “no groups” user, then compare with <code>maria.gomez</code> or <code>diego.rodriguez</code>.
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container">
    <div class="row g-3">
        <div class="col-12 col-lg-4">
            <div class="mb-card rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h5">LDAP stays the truth</h2>
                    <p class="text-muted mb-0">Users and groups live in LDAP; Keycloak federates them and emits group claims.</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="mb-card rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h5">Keycloak issues JWTs</h2>
                    <p class="text-muted mb-0">Apps authenticate with OIDC (Auth Code + PKCE) and call APIs with access tokens.</p>
                </div>
            </div>
        </div>
        <div class="col-12 col-lg-4">
            <div class="mb-card rounded-4 h-100">
                <div class="card-body">
                    <h2 class="h5">Policies are group-based</h2>
                    <p class="text-muted mb-0">Backend policies check the <code>groups</code> claim (mapped from LDAP group membership).</p>
                </div>
            </div>
        </div>
    </div>
</div>
